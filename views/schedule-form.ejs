<!DOCTYPE html>
<html lang="pt-BR" style="font-size: <%= typeof ui !== 'undefined' ? ui.fontScale : '100' %>%;">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= mode === 'new' ? 'Novo agendamento' : 'Editar agendamento' %> - PS Panel</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/styles.css">
    <style>
        .form-box { background-color: var(--bg-light); border-radius: 0.5rem; padding: 1.5rem; max-width: 640px; }
        .form-group { margin-bottom: 1.25rem; }
        .form-group label { display: block; margin-bottom: 0.5rem; color: var(--text-secondary); }
        .form-group input[type="text"], .form-group input[type="number"], .form-group select, .form-group textarea {
            width: 100%; max-width: 100%; padding: 0.75rem; border-radius: 0.375rem; border: 1px solid var(--border-color);
            background: var(--bg-darker); color: var(--text-primary);
        }
        .form-group textarea { min-height: 4rem; font-family: monospace; }
        .hint { font-size: 0.85rem; color: var(--text-secondary); margin-top: 0.35rem; }
        .form-actions { display: flex; gap: 1rem; margin-top: 1.5rem; }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="sidebar-header">
            <a href="/" style="text-decoration: none; color: inherit;">
                <i class="fas fa-terminal"></i>
                <h2>PS Panel</h2>
            </a>
        </div>
        <nav class="sidebar-nav">
            <a href="/"><i class="fas fa-code"></i> Scripts</a>
            <a href="/schedules" class="active"><i class="fas fa-clock"></i> Agendamentos</a>
            <a href="/history"><i class="fas fa-history"></i> Histórico</a>
            <a href="/settings"><i class="fas fa-cog"></i> Configurações</a>
        </nav>
        <div class="sidebar-footer">
            <div class="user-info">
                <span class="user-info1"><i class="fas fa-user"></i> <%= user.displayName || user.username %></span>
            </div>
            <a href="/logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i> Sair</a>
        </div>
    </div>

    <main class="main-content">
        <header class="top-header">
            <div class="header-title">
                <h1><%= mode === 'new' ? 'Novo agendamento' : 'Editar agendamento' %></h1>
                <p><a href="/schedules" class="header-back-link"><i class="fas fa-arrow-left" aria-hidden="true"></i> Voltar à lista</a></p>
            </div>
        </header>

        <% if (messages.error && messages.error.length) { %>
            <div class="alert alert-danger"><%= messages.error[0] %></div>
        <% } %>

        <div class="form-box">
            <form method="POST" action="<%= mode === 'new' ? '/schedules' : '/schedules/' + schedule.id %>">
                <div class="form-group">
                    <label for="script_name">Script (.ps1 em scripts-ps)</label>
                    <select name="script_name" id="script_name" required>
                        <% scripts.forEach(function (f) { %>
                            <option value="<%= f %>" <%= (schedule && schedule.script_name === f) ? 'selected' : '' %>><%= f %></option>
                        <% }); %>
                    </select>
                </div>
                <div class="form-group">
                    <label for="parameters">Parâmetros (linha de comando, separados por espaço — igual ao painel)</label>
                    <textarea name="parameters" id="parameters" placeholder="Ex.: -Verbose"><%= schedule ? (schedule.parameters || '') : '' %></textarea>
                </div>
                <div class="form-group">
                    <label for="next_run_at">Primeira / próxima execução (horário local)</label>
                    <input type="datetime-local" name="next_run_at" id="next_run_at" required value="<%= next_run_local %>">
                </div>
                <div class="form-group">
                    <label for="repeat_interval_minutes">Repetir a cada (minutos)</label>
                    <input type="number" name="repeat_interval_minutes" id="repeat_interval_minutes" min="1" step="1"
                        placeholder="vazio = executar uma vez e desativar"
                        value="<%= schedule && schedule.repeat_interval_minutes != null ? schedule.repeat_interval_minutes : '' %>">
                    <p class="hint">Deixe em branco para <strong>uma execução</strong> (após sucesso o agendamento fica inativo). Preencha, por exemplo, <code>60</code> para rodar de hora em hora após cada conclusão com sucesso.</p>
                </div>
                <div class="form-group">
                    <label><input type="checkbox" name="enabled" value="1" <%= (!schedule || schedule.enabled) ? 'checked' : '' %>> Ativo</label>
                </div>
                <div class="form-actions">
                    <button type="submit" class="primary-btn"><i class="fas fa-save"></i> Salvar</button>
                    <a href="/schedules" class="secondary-btn">Cancelar</a>
                </div>
            </form>
        </div>
    </main>
</body>
</html>
