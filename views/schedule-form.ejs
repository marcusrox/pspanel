<!DOCTYPE html>
<html lang="pt-BR" style="font-size: <%= typeof ui !== 'undefined' ? ui.fontScale : '100' %>%;">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= mode === 'new' ? 'Novo agendamento' : 'Editar agendamento' %> - PS Panel</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/styles.css">
    <style>
        .form-box { background-color: var(--bg-light); border-radius: 0.5rem; padding: 1.5rem; max-width: 760px; }
        .form-group { margin-bottom: 1.25rem; }
        .form-group label { display: block; margin-bottom: 0.5rem; color: var(--text-secondary); }
        .form-group input[type="text"], .form-group input[type="number"], .form-group select, .form-group textarea {
            width: 100%; max-width: 100%; padding: 0.75rem; border-radius: 0.375rem; border: 1px solid var(--border-color);
            background: var(--bg-darker); color: var(--text-primary);
        }
        .form-group textarea { min-height: 4rem; font-family: monospace; }
        .parameter-fields { display: none; border: 1px solid var(--border-color); border-radius: 0.5rem; padding: 1rem; margin-bottom: 1.25rem; background: var(--bg-darker); }
        .parameter-fields.is-visible { display: block; }
        .parameter-fields h2 { font-size: 1rem; margin: 0 0 1rem; color: var(--text-primary); }
        .parameter-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1rem; }
        .parameter-field label { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem; color: var(--text-secondary); }
        .parameter-field input,
        .parameter-field select {
            width: 100%; max-width: 100%; padding: 0.75rem; border-radius: 0.375rem; border: 1px solid var(--border-color);
            background: var(--bg-light); color: var(--text-primary);
        }
        .mandatory-badge { font-size: 0.72rem; padding: 0.15rem 0.45rem; border-radius: 999px; background: rgba(239, 68, 68, 0.16); color: #fca5a5; }
        .parameter-meta { font-size: 0.8rem; color: var(--text-secondary); margin-top: 0.35rem; }
        .hint { font-size: 0.85rem; color: var(--text-secondary); margin-top: 0.35rem; }
        .schedule-time-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1rem; margin-bottom: 1.25rem; }
        .schedule-time-grid .form-group { margin-bottom: 0; }
        .form-group .checkbox-field {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            width: auto;
            margin-bottom: 0;
            color: var(--text-secondary);
            cursor: pointer;
        }
        .form-group .checkbox-field input[type="checkbox"] {
            flex: 0 0 auto;
            width: auto;
            margin: 0;
        }
        .form-actions { display: flex; gap: 1rem; margin-top: 1.5rem; }
    </style>
</head>
<body>
    <%- include('partials/sidebar', { activeMenu: 'schedules', user: user }) %>

    <main class="main-content">
        <header class="top-header">
            <div class="header-title">
                <h1><%= mode === 'new' ? 'Novo agendamento' : 'Editar agendamento' %></h1>
                <p><a href="/schedules" class="header-back-link"><i class="fas fa-arrow-left" aria-hidden="true"></i> Voltar à lista</a></p>
            </div>
        </header>

        <% if (messages.error && messages.error.length) { %>
            <div class="alert alert-danger"><%= messages.error[0] %></div>
        <% } %>

        <div class="form-box">
            <form method="POST" action="<%= mode === 'new' ? '/schedules' : '/schedules/' + schedule.id %>">
                <div class="form-group">
                    <label for="script_name">Script (.ps1 em scripts-ps)</label>
                    <select name="script_name" id="script_name" required>
                        <% scripts.forEach(function (scriptItem) { %>
                            <option value="<%= scriptItem.name %>" <%= (schedule && schedule.script_name === scriptItem.name) ? 'selected' : '' %>><%= scriptItem.name %></option>
                        <% }); %>
                    </select>
                </div>

                <div id="parameterFields" class="parameter-fields" aria-live="polite">
                    <h2>Parâmetros do script</h2>
                    <div id="parameterGrid" class="parameter-grid"></div>
                </div>

                <div class="form-group">
                    <label for="parameters">Parâmetros adicionais</label>
                    <textarea name="parameters" id="parameters" placeholder="Ex.: -Verbose"><%= additionalParameters || '' %></textarea>
                    <p class="hint">Use este campo apenas para opções adicionais. Parâmetros declarados no script devem ser preenchidos nos campos acima.</p>
                </div>
                <div class="schedule-time-grid">
                    <div class="form-group">
                        <label for="next_run_at">Primeira / próxima execução (horário local)</label>
                        <input type="datetime-local" name="next_run_at" id="next_run_at" required value="<%= next_run_local %>">
                    </div>
                    <div class="form-group">
                        <label for="repeat_interval_minutes">Repetir a cada (minutos)</label>
                        <input type="number" name="repeat_interval_minutes" id="repeat_interval_minutes" min="1" step="1"
                            placeholder="vazio = executar uma vez e desativar"
                            value="<%= schedule && schedule.repeat_interval_minutes != null ? schedule.repeat_interval_minutes : '' %>">
                        <p class="hint">Deixe em branco para <strong>uma execução</strong> (após sucesso o agendamento fica inativo). Preencha, por exemplo, <code>60</code> para rodar de hora em hora após cada conclusão com sucesso.</p>
                    </div>
                </div>
                <div class="form-group">
                    <label class="checkbox-field">
                        <input type="checkbox" name="enabled" value="1" <%= (!schedule || schedule.enabled) ? 'checked' : '' %>>
                        <span>Ativo</span>
                    </label>
                </div>
                <div class="form-actions">
                    <button type="submit" class="primary-btn"><i class="fas fa-save"></i> Salvar</button>
                    <a href="/schedules" class="secondary-btn">Cancelar</a>
                </div>
            </form>
        </div>
    </main>
    <script>
        const scriptsData = <%- JSON.stringify(scripts || []).replace(/</g, '\\u003c') %>;
        const initialScriptName = <%- JSON.stringify(schedule ? schedule.script_name : '').replace(/</g, '\\u003c') %>;
        const initialParameterValues = <%- JSON.stringify(parameterValues || {}).replace(/</g, '\\u003c') %>;
        let selectedParameterDefinitions = [];

        document.addEventListener('DOMContentLoaded', function () {
            const scriptSelect = document.getElementById('script_name');
            const form = document.querySelector('.form-box form');

            scriptSelect.addEventListener('change', function () {
                renderSelectedScriptParameters(false);
            });

            form.addEventListener('submit', function (event) {
                const missingParameters = getMissingRequiredParameters();
                if (missingParameters.length) {
                    event.preventDefault();
                    alert(`Informe os parâmetros obrigatórios: ${missingParameters.join(', ')}.`);
                }
            });

            renderSelectedScriptParameters(true);
        });

        function getSelectedScriptData() {
            const scriptName = document.getElementById('script_name').value;
            return scriptsData.find((scriptItem) => scriptItem.name === scriptName) || null;
        }

        function renderSelectedScriptParameters(useInitialValues) {
            const scriptData = getSelectedScriptData();
            selectedParameterDefinitions = scriptData
                && scriptData.parameters
                && Array.isArray(scriptData.parameters.parameters)
                    ? scriptData.parameters.parameters
                    : [];

            const values = useInitialValues && scriptData && scriptData.name === initialScriptName
                ? initialParameterValues
                : {};
            renderParameterFields(selectedParameterDefinitions, values);
        }

        function clearParameterFields() {
            const container = document.getElementById('parameterFields');
            const grid = document.getElementById('parameterGrid');
            grid.replaceChildren();
            container.classList.remove('is-visible');
        }

        function renderParameterFields(parameters, values) {
            clearParameterFields();

            if (!parameters || !parameters.length) {
                return;
            }

            const container = document.getElementById('parameterFields');
            const grid = document.getElementById('parameterGrid');
            const initialValues = values || {};

            parameters.forEach((param) => {
                const field = document.createElement('div');
                field.className = 'parameter-field';

                const label = document.createElement('label');
                label.setAttribute('for', `param-${param.name}`);
                label.appendChild(document.createTextNode(param.name));

                if (param.mandatory) {
                    const badge = document.createElement('span');
                    badge.className = 'mandatory-badge';
                    badge.textContent = 'Obrigatório';
                    label.appendChild(badge);
                }

                const input = Array.isArray(param.validateSet) && param.validateSet.length
                    ? document.createElement('select')
                    : document.createElement('input');

                input.id = `param-${param.name}`;
                input.name = `paramValues[${param.name}]`;
                input.required = Boolean(param.mandatory);

                if (input.tagName === 'SELECT') {
                    const emptyOption = document.createElement('option');
                    emptyOption.value = '';
                    emptyOption.textContent = 'Selecione...';
                    input.appendChild(emptyOption);

                    param.validateSet.forEach((optionValue) => {
                        const option = document.createElement('option');
                        option.value = optionValue;
                        option.textContent = optionValue;
                        input.appendChild(option);
                    });
                } else {
                    input.type = 'text';
                    input.placeholder = param.defaultValue
                        ? `Padrão: ${param.defaultValue}`
                        : `Valor de ${param.name}`;
                }

                if (initialValues[param.name] !== undefined && initialValues[param.name] !== null) {
                    input.value = initialValues[param.name];
                }

                field.appendChild(label);
                field.appendChild(input);

                if (param.type || param.defaultValue) {
                    const meta = document.createElement('div');
                    meta.className = 'parameter-meta';
                    meta.textContent = [
                        param.type ? `Tipo: ${param.type}` : null,
                        param.defaultValue ? `Padrão: ${param.defaultValue}` : null
                    ].filter(Boolean).join(' | ');
                    field.appendChild(meta);
                }

                grid.appendChild(field);
            });

            container.classList.add('is-visible');
        }

        function getMissingRequiredParameters() {
            const rawParamValues = parseRawNamedParameterValues(
                document.getElementById('parameters').value,
                selectedParameterDefinitions
            );

            return selectedParameterDefinitions
                .filter((param) => param.mandatory)
                .filter((param) => {
                    const input = document.getElementById(`param-${param.name}`);
                    const structuredValue = input ? input.value.trim() : '';
                    return !structuredValue && !rawParamValues[param.name];
                })
                .map((param) => param.name);
        }

        function parseRawNamedParameterValues(rawParams, parameters) {
            const values = {};
            if (!rawParams || !rawParams.trim()) {
                return values;
            }

            const tokens = rawParams.trim().match(/"[^"]*"|'[^']*'|\S+/g) || [];
            const knownNames = new Map(parameters.map((param) => [param.name.toLowerCase(), param.name]));

            for (let i = 0; i < tokens.length; i++) {
                const token = tokens[i];
                if (!token.startsWith('-')) {
                    continue;
                }

                const canonicalName = knownNames.get(token.slice(1).toLowerCase());
                if (!canonicalName) {
                    continue;
                }

                const nextToken = tokens[i + 1];
                if (!nextToken || nextToken.startsWith('-')) {
                    values[canonicalName] = 'true';
                    continue;
                }

                values[canonicalName] = nextToken.replace(/^['"]|['"]$/g, '');
                i++;
            }

            return values;
        }
    </script>
</body>
</html>
