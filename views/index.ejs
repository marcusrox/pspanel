<!DOCTYPE html>
<html lang="pt-BR" style="font-size: <%= typeof ui !== 'undefined' ? ui.fontScale : '100' %>%;">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Painel de Scripts - Administração</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <script src="https://unpkg.com/htmx.org@1.9.10"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/styles.css">
    <link rel="stylesheet" href="/css/index/rename-script-modal.css">
    <style>
        .loading-overlay {
            display: none;
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: rgba(15, 23, 42, 0.8);
            justify-content: center;
            align-items: center;
            border-radius: 0.5rem;
            z-index: 10;
        }

        .loading-content {
            text-align: center;
            color: var(--text-primary);
        }

        .spinner {
            display: inline-block;
            width: 50px;
            height: 50px;
            border: 3px solid rgba(255, 255, 255, 0.3);
            border-radius: 50%;
            border-top-color: var(--primary-color);
            animation: spin 1s ease-in-out infinite;
            margin-bottom: 1rem;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        .script-layout {
            display: block;
        }

        .script-form {
            position: relative;
            padding: 0;
        }

        .script-workspace {
            display: grid;
            grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
            align-items: stretch;
            gap: 2rem;
        }

        .script-panel,
        .parameters-panel {
            position: relative;
            min-height: 200px;
            background-color: var(--bg-light);
            border: 1px solid var(--border-color);
            border-radius: 0.5rem;
        }

        .panel-body {
            padding: 1.5rem;
        }

        .output-panel {
            position: relative;
            min-height: 200px;
            margin-top: 2rem;
        }

        .execution-status {
            display: none;
            margin-top: 1rem;
            padding: 0.75rem;
            border-radius: 0.375rem;
            text-align: center;
            font-weight: 500;
        }

        .execution-status.running {
            display: block;
            background-color: var(--bg-darker);
            color: var(--text-secondary);
            border: 1px solid var(--border-color);
        }

        .execution-status.success {
            display: block;
            background-color: rgba(34, 197, 94, 0.1);
            color: var(--success-color);
            border: 1px solid var(--success-color);
        }

        .execution-status.error {
            display: block;
            background-color: rgba(239, 68, 68, 0.1);
            color: var(--danger-color);
            border: 1px solid var(--danger-color);
        }

        .htmx-request .loading-overlay {
            display: flex !important;
        }

        .primary-btn:disabled {
            opacity: 0.7;
            cursor: not-allowed;
        }

        .secondary-btn:disabled {
            opacity: 0.7;
            cursor: not-allowed;
        }

        .parameter-fields {
            display: block;
            margin-bottom: 1.5rem;
        }

        .parameter-empty-state {
            min-height: 7rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            padding: 1.25rem;
            text-align: center;
            color: var(--text-secondary);
            background-color: var(--bg-darker);
            border: 1px dashed var(--border-color);
            border-radius: 0.5rem;
        }

        .parameter-empty-state i {
            color: var(--primary-color);
            font-size: 1.5rem;
        }

        .parameter-empty-state[hidden] {
            display: none;
        }

        .parameter-help-btn {
            width: 2rem;
            height: 2rem;
            display: none;
            align-items: center;
            justify-content: center;
            border: 1px solid var(--border-color);
            border-radius: 50%;
            background-color: var(--bg-light);
            color: var(--text-secondary);
            cursor: pointer;
            transition: background-color 0.15s ease, color 0.15s ease, border-color 0.15s ease;
            flex: 0 0 auto;
        }

        .parameter-help-btn.is-visible {
            display: inline-flex;
        }

        .parameter-help-btn:hover,
        .parameter-help-btn:focus {
            background-color: rgba(37, 99, 235, 0.12);
            border-color: var(--primary-color);
            color: var(--primary-color);
            outline: none;
        }

        .parameter-grid {
            display: grid;
            gap: 0.85rem;
        }

        .parameter-field {
            display: grid;
            gap: 0.4rem;
            position: relative;
        }

        .parameter-label-row {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            min-width: 0;
        }

        .parameter-field label {
            display: flex;
            align-items: center;
            flex-wrap: wrap;
            gap: 0.5rem;
            color: var(--text-secondary);
            font-size: 0.875rem;
        }

        .parameter-field-help-btn {
            width: 1.65rem;
            height: 1.65rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            flex: 0 0 auto;
            border: 1px solid var(--border-color);
            border-radius: 50%;
            background-color: var(--bg-light);
            color: var(--text-secondary);
            cursor: pointer;
            font-size: 0.75rem;
            transition: background-color 0.15s ease, color 0.15s ease, border-color 0.15s ease;
        }

        .parameter-field-help-btn:hover,
        .parameter-field-help-btn:focus-visible,
        .parameter-field-help-btn[aria-expanded="true"] {
            background-color: rgba(37, 99, 235, 0.12);
            border-color: var(--primary-color);
            color: var(--primary-color);
            outline: none;
        }

        .parameter-help-wrapper {
            position: relative;
            display: inline-flex;
            flex: 0 0 auto;
        }

        .parameter-field-help {
            position: absolute;
            top: calc(100% + 0.4rem);
            left: 50%;
            z-index: 20;
            width: max-content;
            min-width: 12rem;
            max-width: min(24rem, calc(100vw - 2rem));
            padding: 0.65rem 0.75rem;
            border: 1px solid var(--primary-color);
            border-radius: 0.375rem;
            background-color: var(--bg-light);
            box-shadow: 0 0.75rem 1.5rem rgba(0, 0, 0, 0.28);
            color: var(--text-primary);
            font-size: 0.82rem;
            line-height: 1.45;
            overflow-wrap: anywhere;
            transform: translateX(-50%);
        }

        .parameter-field-help::before {
            content: '';
            position: absolute;
            left: 50%;
            bottom: 100%;
            border: 0.35rem solid transparent;
            border-bottom-color: var(--primary-color);
            transform: translateX(-50%);
        }

        .parameter-field-help[hidden] {
            display: none;
        }

        .parameter-field input.restored-password-value {
            letter-spacing: 0.16em;
        }

        .parameter-field input,
        .parameter-field select {
            width: 100%;
            background-color: var(--bg-dark);
            border: 1px solid var(--border-color);
            color: var(--text-primary);
            border-radius: 0.375rem;
            padding: 0.75rem;
            font-size: 0.95rem;
        }

        .parameter-field input:focus,
        .parameter-field select:focus {
            outline: none;
            border-color: var(--primary-color);
        }

        .parameter-meta {
            color: var(--text-secondary);
            font-size: 0.78rem;
        }

        .sidebar-footer {
            margin-top: auto;
            padding: 1rem;
            border-top: 1px solid var(--border-color);
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .user-info {
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
        }

        .user-info {
            font-size: 0.875rem;
            color: var(--text-secondary);
            
        }

        .user-info2 {
            padding-left: 1.5rem;
        }

        .logout-btn {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            color: var(--danger-color);
            text-decoration: none;
            font-size: 0.875rem;
            padding: 0.5rem;
            border-radius: 0.375rem;
            transition: background-color 0.2s;
        }

        .logout-btn:hover {
            background-color: rgba(239, 68, 68, 0.1);
        }

        .script-info {
            margin: 1rem 0;
            padding: 1rem;
            background-color: var(--bg-darker);
            border: 1px solid var(--border-color);
            border-radius: 0.375rem;
            display: none;
        }

        .script-info .info-content {
            color: var(--text-secondary);
        }

        .script-info h3 {
            font-size: 0.875rem;
            color: var(--text-primary);
            margin: 0 0 0.75rem 0;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .script-info .param-item {
            margin: 0.5rem 0;
            padding-left: 1.5rem;
            position: relative;
        }

        .script-info .param-item::before {
            content: "•";
            position: absolute;
            left: 0.5rem;
            color: var(--primary-color);
        }

        .script-info .param-options {
            margin-top: 0.25rem;
            font-size: 0.8125rem;
            color: var(--text-secondary);
            padding-left: 1rem;
        }

        .script-info .param-options span {
            color: var(--primary-color);
        }

        .script-form .form-actions {
            align-items: center;
            flex-wrap: wrap;
        }

        .saved-parameters-clear-btn {
            width: 2.25rem;
            height: 2.25rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-left: auto;
            padding: 0;
            border: 0;
            background: transparent;
            color: #ef4444;
            cursor: pointer;
            font-size: 1rem;
        }

        .saved-parameters-clear-btn:hover,
        .saved-parameters-clear-btn:focus-visible {
            background: transparent;
            color: #f87171;
            outline: 2px solid rgba(239, 68, 68, 0.45);
            outline-offset: 2px;
        }

        .saved-parameters-clear-btn:disabled {
            color: var(--text-secondary);
            cursor: not-allowed;
            opacity: 0.4;
        }

        .script-panel-actions {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        @media (max-width: 1024px) {
            .script-workspace {
                grid-template-columns: minmax(0, 1fr);
            }
        }

        .script-help-modal {
            display: none;
            position: fixed;
            inset: 0;
            background-color: rgba(15, 23, 42, 0.72);
            z-index: 1000;
            padding: 2rem;
        }

        .script-help-modal.is-open {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .script-help-content {
            position: relative;
            width: min(760px, 100%);
            max-height: 85vh;
            overflow-y: auto;
            background-color: var(--bg-light);
            border: 1px solid var(--border-color);
            border-radius: 0.5rem;
            padding: 1.5rem;
            box-shadow: 0 24px 60px rgba(0, 0, 0, 0.35);
        }

        .script-help-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 1rem;
            margin-bottom: 1rem;
        }

        .script-help-header h2 {
            margin: 0;
            font-size: 1.25rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .script-help-body {
            display: grid;
            gap: 1rem;
            color: var(--text-secondary);
            line-height: 1.6;
        }

        .script-help-body h3 {
            margin: 0 0 0.35rem;
            color: var(--text-primary);
            font-size: 1rem;
        }

        .script-help-body p,
        .script-help-body ul {
            margin: 0;
        }

        .script-help-body ul {
            padding-left: 1.25rem;
        }

        .script-help-body code {
            color: var(--text-primary);
        }

        #executeBtn {
            max-width: 100%;
        }

        #executeBtnText {
            overflow-wrap: anywhere;
            text-align: left;
        }

        .scripts-table-wrap {
            border: 1px solid var(--border-color);
            border-radius: 0.5rem;
            overflow: auto;
            max-height: 320px;
            background-color: var(--bg-darker);
        }

        .scripts-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.9rem;
        }

        .scripts-table th,
        .scripts-table td {
            padding: 0.75rem 1rem;
            text-align: left;
            border-bottom: 1px solid var(--border-color);
            vertical-align: top;
        }

        .scripts-table th {
            background-color: var(--bg-light);
            color: var(--text-secondary);
            font-weight: 600;
            position: sticky;
            top: 0;
            z-index: 1;
        }

        .scripts-table tbody tr {
            cursor: pointer;
            transition: background-color 0.15s ease;
        }

        .scripts-table tbody tr:hover {
            background-color: rgba(37, 99, 235, 0.08);
        }

        .scripts-table tbody tr.is-selected {
            background-color: rgba(37, 99, 235, 0.18);
            box-shadow: inset 3px 0 0 var(--primary-color);
        }

        .scripts-table .script-name-cell {
            font-weight: 600;
            color: var(--text-primary);
            font-family: 'Consolas', 'Monaco', monospace;
            font-size: 0.875rem;
        }

        .scripts-table .script-actions-cell {
            width: 6rem;
            text-align: center;
            vertical-align: middle;
        }

        .script-action-buttons {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.4rem;
            opacity: 0;
            visibility: hidden;
            pointer-events: none;
            transition: opacity 0.15s ease, visibility 0.15s ease;
        }

        .scripts-table tbody tr:hover .script-action-buttons,
        .scripts-table tbody tr:focus-within .script-action-buttons {
            opacity: 1;
            visibility: visible;
            pointer-events: auto;
        }

        .source-view-btn,
        .rename-script-btn {
            width: 2.25rem;
            height: 2.25rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: 1px solid var(--border-color);
            border-radius: 0.375rem;
            background-color: var(--bg-light);
            color: var(--text-secondary);
            cursor: pointer;
            transition: background-color 0.15s ease, color 0.15s ease, border-color 0.15s ease;
        }

        .source-view-btn:hover,
        .source-view-btn:focus,
        .rename-script-btn:hover,
        .rename-script-btn:focus {
            background-color: rgba(37, 99, 235, 0.12);
            border-color: var(--primary-color);
            color: var(--primary-color);
            outline: none;
        }

        .scripts-table .script-synopsis {
            display: block;
            margin-top: 0.35rem;
            font-weight: 400;
            color: var(--text-secondary);
            font-size: 0.8125rem;
            line-height: 1.45;
            white-space: pre-wrap;
            max-width: 42rem;
        }

        .scripts-table .script-synopsis.muted {
            font-style: italic;
            opacity: 0.75;
        }

        .mandatory-badge {
            font-size: 0.75rem;
            background-color: rgba(239, 68, 68, 0.1);
            color: #ef4444;
            padding: 0.25rem 0.5rem;
            border-radius: 0.25rem;
            margin-left: 0.5rem;
            border: 1px solid rgba(239, 68, 68, 0.2);
        }

        .param-content {
            background-color: var(--bg-dark);
            padding: 1rem;
            border-radius: 0.375rem;
            border: 1px solid var(--border-color);
            margin-top: 0.5rem;
        }

        .param-content pre {
            margin: 0;
            white-space: pre-wrap;
            word-wrap: break-word;
            color: var(--text-primary);
            font-family: 'Consolas', 'Monaco', 'Courier New', monospace;
            font-size: 0.875rem;
            line-height: 1.5;
        }

        .param-content pre strong {
            color: var(--primary-color);
            font-weight: 600;
        }

    </style>
</head>

<body data-storage-user="<%= user && user.username ? user.username : 'anonymous' %>">
    <%- include('partials/sidebar', { activeMenu: 'scripts', user: user }) %>

    <main class="main-content">
        <header class="top-header">
            <div class="header-title">
                <h1>Painel de Scripts</h1>
                <p>Execute e gerencie seus scripts PowerShell</p>
            </div>
            <div class="header-actions">
                <button type="button" class="icon-btn" title="Ajuda" aria-label="Ajuda" onclick="openScriptHelpModal()">
                    <i class="fas fa-circle-question"></i>
                </button>
                <img src="/logo.png" alt="Logo" class="header-logo">
            </div>
        </header>

        <div class="content-wrapper script-layout">
            <form class="script-form"
                  hx-post="/run-script"
                  hx-target="#output"
                  hx-swap="innerHTML"
                  hx-trigger="submit"
                  hx-indicator=".loading-overlay"
                  novalidate>
                <input type="hidden" name="script" id="script" value="">

                <div class="script-workspace">
                    <div class="script-panel">
                        <div class="panel-header">
                            <h2><i class="fas fa-play-circle"></i> Executar Script</h2>
                            <div class="script-panel-actions">
                                <button type="button" class="icon-btn" title="Atualizar lista de scripts" aria-label="Atualizar lista de scripts" onclick="window.location.reload()">
                                    <i class="fas fa-arrows-rotate"></i>
                                </button>
                            </div>
                        </div>

                        <div class="panel-body">
                            <div class="form-group">
                                <label id="script-table-label">
                                    <i class="fas fa-file-code"></i> Scripts disponíveis - Clique em uma linha para selecionar o script a executar.
                                </label>
                                <div class="scripts-table-wrap" role="grid" aria-labelledby="script-table-label">
                                    <table class="scripts-table">
                                        <tbody>
                                            <% if (!scripts.length) { %>
                                                <tr><td class="script-synopsis muted">Nenhum arquivo .ps1 encontrado em <code>scripts-ps</code>.</td></tr>
                                            <% } %>
                                            <% scripts.forEach(function (script) {
                                                const paramsB64 = Buffer.from(JSON.stringify(script.parameters || null)).toString('base64');
                                            %>
                                                <tr class="script-row"
                                                    data-script-name="<%= script.name %>"
                                                    data-params-b64="<%= paramsB64 %>"
                                                    role="row"
                                                    tabindex="0"
                                                    onclick="selectScriptRow(this)"
                                                    onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();selectScriptRow(this);}">
                                                    <td class="script-name-cell">
                                                        <%= script.name %>
                                                        <% if (script.synopsis) { %>
                                                            <span class="script-synopsis"><%= script.synopsis %></span>
                                                        <% } else { %>
                                                            <span class="script-synopsis muted">Sem bloco de ajuda (.SYNOPSIS) no comentário &lt;# #&gt;.</span>
                                                        <% } %>
                                                    </td>
                                                    <td class="script-actions-cell">
                                                        <div class="script-action-buttons">
                                                            <button type="button"
                                                                    class="source-view-btn"
                                                                    title="Visualizar codigo fonte"
                                                                    aria-label="Visualizar codigo fonte de <%= script.name %>"
                                                                    data-source-url="/scripts/<%= encodeURIComponent(script.name) %>/source"
                                                                    onclick="openScriptSource(event, this)">
                                                                <i class="fas fa-eye"></i>
                                                            </button>
                                                            <button type="button"
                                                                    class="rename-script-btn"
                                                                    title="Alterar nome do script"
                                                                    aria-label="Alterar nome de <%= script.name %>"
                                                                    data-script-name="<%= script.name %>"
                                                                    data-rename-url="/scripts/<%= encodeURIComponent(script.name) %>/rename"
                                                                    onclick="renameScript(event, this)">
                                                                <i class="fas fa-pen"></i>
                                                            </button>
                                                        </div>
                                                    </td>
                                                </tr>
                                            <% }); %>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="parameters-panel">
                        <div class="panel-header">
                            <h2><i class="fas fa-sliders-h"></i> Parâmetros</h2>
                            <button type="button"
                                    id="parameterHelpBtn"
                                    class="parameter-help-btn"
                                    title="Mostrar parâmetros necessários"
                                    aria-label="Mostrar parâmetros necessários"
                                    aria-expanded="false"
                                    aria-controls="scriptInfo"
                                    onclick="toggleParameterInfo()">
                                <i class="fas fa-question"></i>
                            </button>
                        </div>

                        <div class="panel-body">
                            <div id="parameterFields" class="parameter-fields" aria-live="polite">
                                <div id="parameterEmptyState" class="parameter-empty-state">
                                    <i class="fas fa-arrow-pointer"></i>
                                    <span>Selecione um script para visualizar seus parâmetros.</span>
                                </div>
                                <div id="scriptInfo" class="script-info" style="display: none;">
                                    <div class="info-content">
                                        <h3><i class="fas fa-info-circle"></i> Parâmetros Necessários:</h3>
                                        <div id="paramsList"></div>
                                    </div>
                                </div>
                                <div id="parameterGrid" class="parameter-grid"></div>
                            </div>

                            <div class="form-group">
                                <label for="params">
                                    <i class="fas fa-terminal"></i> Parâmetros adicionais:
                                </label>
                                <input type="text"
                                       name="params"
                                       id="params"
                                       placeholder="Opcional. Ex: -Verbose -Force">
                            </div>

                            <div class="form-actions">
                                <button type="button" class="secondary-btn" onclick="clearScriptForm()">
                                    <i class="fas fa-undo"></i> Limpar
                                </button>
                                <button type="submit" class="primary-btn" id="executeBtn">
                                    <i class="fas fa-play"></i>
                                    <span id="executeBtnText">Executar</span>
                                </button>
                                <button type="button"
                                        class="saved-parameters-clear-btn"
                                        id="clearSavedParametersBtn"
                                        title="Remove deste navegador os parâmetros salvos do script selecionado"
                                        aria-label="Remover deste navegador os parâmetros salvos do script selecionado"
                                        onclick="clearSavedScriptParameters()"
                                        disabled>
                                    <i class="fas fa-trash-can" aria-hidden="true"></i>
                                </button>
                            </div>

                            <div class="execution-status" id="executionStatus"></div>
                        </div>
                    </div>
                </div>

                <div class="loading-overlay">
                    <div class="loading-content">
                        <div class="spinner"></div>
                        <p>Executando script...</p>
                    </div>
                </div>
            </form>

            <div class="output-panel">
                <div class="panel-header">
                    <h2><i class="fas fa-terminal"></i> Saída do Script</h2>
                    <div class="panel-actions">
                        <button class="icon-btn" title="Limpar Saída" onclick="clearOutput()">
                            <i class="fas fa-eraser"></i>
                        </button>
                        <button class="icon-btn" title="Copiar" onclick="copyOutput()">
                            <i class="fas fa-copy"></i>
                        </button>
                    </div>
                </div>
                <div id="output" class="output-content">
                    <div class="output-placeholder">
                        <i class="fas fa-terminal"></i>
                        <p>A saída do script será exibida aqui</p>
                    </div>
                </div>
            </div>
        </div>

        <%- include('partials/app-footer') %>
    </main>

    <%- include('partials/rename-script-modal') %>

    <div id="scriptHelpModal" class="script-help-modal" role="dialog" aria-modal="true" aria-labelledby="scriptHelpTitle">
        <div class="script-help-content">
            <div class="script-help-header">
                <h2 id="scriptHelpTitle"><i class="fas fa-circle-question"></i> Ajuda do Painel de Scripts</h2>
                <button type="button" class="icon-btn" title="Fechar ajuda" aria-label="Fechar ajuda" onclick="closeScriptHelpModal()">
                    <i class="fas fa-xmark"></i>
                </button>
            </div>
            <div class="script-help-body">
                <section>
                    <h3>Como executar</h3>
                    <p>Selecione um script na lista, preencha os parâmetros exigidos e clique em <strong>Executar</strong>. O nome do script selecionado aparece no próprio botão para confirmar o que será enviado.</p>
                </section>
                <section>
                    <h3>Parâmetros</h3>
                    <ul>
                        <li>Parâmetros declarados no bloco <code>param(...)</code> do PowerShell aparecem como campos individuais.</li>
                        <li>Campos obrigatórios precisam ser preenchidos antes da execução.</li>
                        <li>Use <strong>Parâmetros adicionais</strong> apenas para opções extras, como <code>-Verbose</code> ou flags específicas.</li>
                    </ul>
                </section>
                <section>
                    <h3>Saída e erros</h3>
                    <p>A saída do script é exibida no painel abaixo dos cartões de execução e parâmetros. Erros de execução também ficam registrados no histórico e nos logs da aplicação quando o script retorna código de falha.</p>
                </section>
                <section>
                    <h3>Ações úteis</h3>
                    <ul>
                        <li>Use o ícone de atualizar no cabeçalho <strong>Executar Script</strong> para recarregar a lista após criar, remover ou renomear scripts.</li>
                        <li>Use o ícone de olho na linha do script para visualizar o código fonte.</li>
                        <li>Use o ícone de caneta para renomear um script.</li>
                    </ul>
                </section>
            </div>
        </div>
    </div>

    <script src="/js/index/rename-script-modal.js"></script>
    <script>
        const SCRIPT_PARAMETERS_STORAGE_KEY = 'pspanel.scriptParameters.v1';
        const parameterSaveTimers = new Map();
        let selectedParameterDefinitions = [];
        let openParameterHelpButton = null;

        document.addEventListener('DOMContentLoaded', function() {
            const form = document.querySelector('.script-form');
            const status = document.getElementById('executionStatus');
            const executeBtn = document.getElementById('executeBtn');
            const additionalParametersInput = document.getElementById('params');

            // Reseta o estado inicial
            clearExecutionStatus();
            executeBtn.disabled = false;

            // Antes de enviar o formulário
            form.addEventListener('htmx:beforeRequest', function(event) {
                const script = document.getElementById('script').value.trim();
                if (!script) {
                    alert('Por favor, selecione um script na tabela');
                    event.preventDefault();
                    return;
                }

                const missingParameters = getMissingRequiredParameters();
                if (missingParameters.length) {
                    const message = `Informe os parametros obrigatorios: ${missingParameters.join(', ')}.`;
                    showExecutionError(message);
                    event.preventDefault();
                    return;
                }

                executeBtn.disabled = true;
                status.className = 'execution-status running';
                status.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Executando script...';
                status.style.display = 'block';
            });

            // Depois de receber a resposta
            form.addEventListener('htmx:afterRequest', function(event) {
                executeBtn.disabled = false;
                const output = document.getElementById('output');

                if (output && output.innerText) {
                    if (output.innerText.includes('código 0')) {
                        status.className = 'execution-status success';
                        status.innerHTML = '<i class="fas fa-check-circle"></i> Script executado com sucesso!';
                    } else {
                        status.className = 'execution-status error';
                        status.innerHTML = '<i class="fas fa-exclamation-circle"></i> Erro ao executar o script';
                    }
                }

                // Esconde o status após 5 segundos
                setTimeout(() => {
                    status.style.display = 'none';
                    status.className = 'execution-status';
                }, 5000);
            });

            form.addEventListener('htmx:responseError', function(event) {
                executeBtn.disabled = false;
                const message = event.detail.xhr && event.detail.xhr.responseText
                    ? event.detail.xhr.responseText
                    : 'Erro ao executar o script';
                document.getElementById('output').innerHTML = message;
                showExecutionError('Erro ao executar o script');
            });

            form.addEventListener('reset', function () {
                clearScriptSelectionState();
            });

            additionalParametersInput.addEventListener('input', function () {
                scheduleCurrentScriptParametersSave();
            });

            document.addEventListener('keydown', function (event) {
                if (event.key === 'Escape') {
                    closeOpenParameterDescription(true);
                    closeScriptHelpModal();
                }
            });

            document.addEventListener('click', function (event) {
                if (!openParameterHelpButton) {
                    return;
                }

                const helpId = openParameterHelpButton.getAttribute('aria-controls');
                const helpContent = helpId ? document.getElementById(helpId) : null;
                if (openParameterHelpButton.contains(event.target)
                    || (helpContent && helpContent.contains(event.target))) {
                    return;
                }

                closeOpenParameterDescription(false);
            });

            const scriptHelpModal = document.getElementById('scriptHelpModal');
            scriptHelpModal.addEventListener('click', function (event) {
                if (event.target === scriptHelpModal) {
                    closeScriptHelpModal();
                }
            });
        });

        function openScriptHelpModal() {
            document.getElementById('scriptHelpModal').classList.add('is-open');
        }

        function closeScriptHelpModal() {
            document.getElementById('scriptHelpModal').classList.remove('is-open');
        }

        function copyOutput() {
            const output = document.getElementById('output').innerText;
            navigator.clipboard.writeText(output)
                .then(() => {
                    const btn = document.querySelector('[title="Copiar"]');
                    const originalHtml = btn.innerHTML;
                    btn.innerHTML = '<i class="fas fa-check"></i>';
                    setTimeout(() => {
                        btn.innerHTML = originalHtml;
                    }, 2000);
                })
                .catch(err => console.error('Erro ao copiar:', err));
        }

        function clearOutput() {
            const output = document.getElementById('output');
            output.innerHTML = `
                <div class="output-placeholder">
                    <i class="fas fa-terminal"></i>
                    <p>A saída do script será exibida aqui</p>
                </div>
            `;
            clearExecutionStatus();
        }

        function clearScriptForm() {
            const form = document.querySelector('.script-form');
            if (form) {
                form.reset();
            }
            clearScriptSelectionState();
        }

        function clearScriptSelectionState() {
            document.getElementById('script').value = '';
            updateExecuteButtonLabel('');
            document.querySelectorAll('.script-row.is-selected').forEach(function (r) {
                r.classList.remove('is-selected');
            });
            selectedParameterDefinitions = [];
            clearExecutionStatus();
            clearParameterFields();
            updateClearSavedParametersButton();
        }

        function isRecord(value) {
            return Boolean(value) && typeof value === 'object' && !Array.isArray(value);
        }

        function getParameterStorageUserKey() {
            return `user:${encodeURIComponent(document.body.dataset.storageUser || 'anonymous')}`;
        }

        function getParameterStorageScriptKey(scriptName) {
            return `script:${encodeURIComponent(scriptName)}`;
        }

        function readScriptParametersStorage() {
            try {
                const rawState = localStorage.getItem(SCRIPT_PARAMETERS_STORAGE_KEY);
                if (!rawState) {
                    return {};
                }

                const state = JSON.parse(rawState);
                return isRecord(state) ? state : {};
            } catch (error) {
                return {};
            }
        }

        function writeScriptParametersStorage(state) {
            try {
                localStorage.setItem(SCRIPT_PARAMETERS_STORAGE_KEY, JSON.stringify(state));
                return true;
            } catch (error) {
                return false;
            }
        }

        function getSavedScriptParameters(scriptName) {
            if (!scriptName) {
                return null;
            }

            const state = readScriptParametersStorage();
            const userState = state[getParameterStorageUserKey()];
            if (!isRecord(userState)) {
                return null;
            }

            const savedState = userState[getParameterStorageScriptKey(scriptName)];
            if (!isRecord(savedState)) {
                return null;
            }

            return {
                values: isRecord(savedState.values) ? savedState.values : {},
                additionalParameters: typeof savedState.additionalParameters === 'string'
                    ? savedState.additionalParameters
                    : ''
            };
        }

        function captureCurrentScriptParameters() {
            const values = Object.create(null);

            selectedParameterDefinitions.forEach(function (param) {
                const input = document.getElementById(`param-${param.name}`);
                if (input) {
                    values[param.name] = input.value;
                }
            });

            return {
                values,
                additionalParameters: document.getElementById('params').value
            };
        }

        function persistScriptParameters(scriptName, parametersState) {
            if (!scriptName) {
                return;
            }

            const state = readScriptParametersStorage();
            const userKey = getParameterStorageUserKey();
            const scriptKey = getParameterStorageScriptKey(scriptName);

            if (!isRecord(state[userKey])) {
                state[userKey] = {};
            }

            state[userKey][scriptKey] = parametersState;
            writeScriptParametersStorage(state);

            if (document.getElementById('script').value === scriptName) {
                updateClearSavedParametersButton();
            }
        }

        function scheduleCurrentScriptParametersSave() {
            const scriptName = document.getElementById('script').value;
            if (!scriptName) {
                return;
            }

            const parametersState = captureCurrentScriptParameters();
            const existingTimer = parameterSaveTimers.get(scriptName);
            if (existingTimer) {
                clearTimeout(existingTimer);
            }

            const timer = setTimeout(function () {
                parameterSaveTimers.delete(scriptName);
                persistScriptParameters(scriptName, parametersState);
            }, 200);
            parameterSaveTimers.set(scriptName, timer);
        }

        function isPasswordParameter(param) {
            const parameterName = String(param && param.name ? param.name : '').toLowerCase();
            return parameterName.includes('password') || parameterName.includes('senha');
        }

        function prepareRestoredPasswordForEditing(input) {
            if (input.dataset.restoredPassword !== 'true') {
                return;
            }

            input.value = '';
            input.type = 'text';
            input.classList.remove('restored-password-value');
            input.removeAttribute('title');
            delete input.dataset.restoredPassword;
            scheduleCurrentScriptParametersSave();
        }

        function restoreSavedScriptParameters(scriptName) {
            const savedState = getSavedScriptParameters(scriptName);
            const savedValues = savedState ? savedState.values : {};

            selectedParameterDefinitions.forEach(function (param) {
                const input = document.getElementById(`param-${param.name}`);
                const savedValue = savedValues[param.name];
                if (input
                    && Object.prototype.hasOwnProperty.call(savedValues, param.name)
                    && typeof savedValue === 'string') {
                    input.value = savedValue;

                    if (savedValue && input.tagName === 'INPUT' && isPasswordParameter(param)) {
                        input.type = 'password';
                        input.classList.add('restored-password-value');
                        input.dataset.restoredPassword = 'true';
                        input.title = 'Valor carregado do navegador. Clique para informar uma nova senha.';
                    }
                }
            });

            document.getElementById('params').value = savedState
                ? savedState.additionalParameters
                : '';
            updateClearSavedParametersButton();
        }

        function updateClearSavedParametersButton() {
            const button = document.getElementById('clearSavedParametersBtn');
            const scriptName = document.getElementById('script').value;
            button.disabled = !scriptName || !getSavedScriptParameters(scriptName);
        }

        function clearSavedScriptParameters() {
            const scriptName = document.getElementById('script').value;
            if (!scriptName || !getSavedScriptParameters(scriptName)) {
                updateClearSavedParametersButton();
                return;
            }

            if (!confirm(`Remover os parâmetros salvos de ${scriptName} neste navegador?`)) {
                return;
            }

            const pendingTimer = parameterSaveTimers.get(scriptName);
            if (pendingTimer) {
                clearTimeout(pendingTimer);
                parameterSaveTimers.delete(scriptName);
            }

            const state = readScriptParametersStorage();
            const userKey = getParameterStorageUserKey();
            const scriptKey = getParameterStorageScriptKey(scriptName);
            const userState = state[userKey];

            if (isRecord(userState)) {
                delete userState[scriptKey];
                if (!Object.keys(userState).length) {
                    delete state[userKey];
                }
                writeScriptParametersStorage(state);
            }

            selectedParameterDefinitions.forEach(function (param) {
                const input = document.getElementById(`param-${param.name}`);
                if (input) {
                    input.value = '';
                }
            });
            document.getElementById('params').value = '';
            closeOpenParameterDescription(false);
            updateClearSavedParametersButton();
        }

        function updateExecuteButtonLabel(scriptName) {
            const executeBtnText = document.getElementById('executeBtnText');
            executeBtnText.textContent = scriptName ? `Executar (${scriptName})` : 'Executar';
        }

        function decodeParamsFromRow(tr) {
            const b64 = tr.getAttribute('data-params-b64');
            if (!b64) return null;
            try {
                const binary = atob(b64);
                const bytes = Uint8Array.from(binary, (char) => char.charCodeAt(0));
                const json = new TextDecoder('utf-8', { fatal: true }).decode(bytes);
                return JSON.parse(json);
            } catch (e) {
                console.error('Parâmetros do script (base64):', e);
                return null;
            }
        }

        function selectScriptRow(tr) {
            clearExecutionStatus();
            document.querySelectorAll('.script-row.is-selected').forEach(function (r) {
                r.classList.remove('is-selected');
            });
            tr.classList.add('is-selected');
            const name = tr.getAttribute('data-script-name') || '';
            document.getElementById('script').value = name;
            updateExecuteButtonLabel(name);
            const scriptData = decodeParamsFromRow(tr);
            selectedParameterDefinitions = Array.isArray(scriptData && scriptData.parameters)
                ? scriptData.parameters
                : [];
            renderParameterFields(selectedParameterDefinitions);
            restoreSavedScriptParameters(name);
            showScriptInfoForParams(scriptData);
        }

        function openScriptSource(event, button) {
            event.preventDefault();
            event.stopPropagation();

            const url = button.getAttribute('data-source-url');
            window.open(url, 'scriptSource', 'width=1000,height=700,scrollbars=yes,resizable=yes');
        }

        function showScriptInfoForParams(scriptData) {
            const scriptInfo = document.getElementById('scriptInfo');
            const paramsList = document.getElementById('paramsList');
            const helpButton = document.getElementById('parameterHelpBtn');

            if (!scriptData || !scriptData.content) {
                scriptInfo.style.display = 'none';
                paramsList.innerHTML = '';
                helpButton.classList.remove('is-visible');
                helpButton.setAttribute('aria-expanded', 'false');
                return;
            }

            paramsList.replaceChildren(createParameterInfoContent(scriptData.content));
            scriptInfo.style.display = 'none';
            helpButton.classList.add('is-visible');
            helpButton.setAttribute('aria-expanded', 'false');
        }

        function toggleParameterInfo() {
            const scriptInfo = document.getElementById('scriptInfo');
            const helpButton = document.getElementById('parameterHelpBtn');
            const isExpanded = scriptInfo.style.display === 'block';

            scriptInfo.style.display = isExpanded ? 'none' : 'block';
            helpButton.setAttribute('aria-expanded', isExpanded ? 'false' : 'true');
        }

        function createParameterInfoContent(content) {
            const wrapper = document.createElement('div');
            wrapper.className = 'param-content';

            const pre = document.createElement('pre');
            const lines = content.split('\n');

            lines.forEach((line, index) => {
                const trimmed = line.trim();
                if (/^\[[A-Za-z_][\w.]*\]\$[A-Za-z_][\w]*/.test(trimmed)) {
                    const strong = document.createElement('strong');
                    strong.textContent = line;
                    pre.appendChild(strong);
                } else {
                    pre.appendChild(document.createTextNode(line));
                }

                if (index < lines.length - 1) {
                    pre.appendChild(document.createTextNode('\n'));
                }
            });

            wrapper.appendChild(pre);
            return wrapper;
        }

        function clearParameterFields() {
            const grid = document.getElementById('parameterGrid');
            const emptyState = document.getElementById('parameterEmptyState');
            const scriptInfo = document.getElementById('scriptInfo');
            const paramsList = document.getElementById('paramsList');
            const helpButton = document.getElementById('parameterHelpBtn');
            closeOpenParameterDescription(false);
            grid.replaceChildren();
            emptyState.hidden = false;
            emptyState.querySelector('span').textContent = 'Selecione um script para visualizar seus parâmetros.';
            paramsList.innerHTML = '';
            scriptInfo.style.display = 'none';
            helpButton.classList.remove('is-visible');
            helpButton.setAttribute('aria-expanded', 'false');
        }

        function closeOpenParameterDescription(restoreFocus) {
            if (!openParameterHelpButton) {
                return;
            }

            const helpId = openParameterHelpButton.getAttribute('aria-controls');
            const helpContent = helpId ? document.getElementById(helpId) : null;
            openParameterHelpButton.setAttribute('aria-expanded', 'false');
            if (helpContent) {
                helpContent.hidden = true;
            }

            const button = openParameterHelpButton;
            openParameterHelpButton = null;
            if (restoreFocus && button.isConnected) {
                button.focus();
            }
        }

        function toggleParameterDescription(button) {
            const helpId = button.getAttribute('aria-controls');
            const helpContent = helpId ? document.getElementById(helpId) : null;
            if (!helpContent) {
                return;
            }

            const wasExpanded = button.getAttribute('aria-expanded') === 'true';
            closeOpenParameterDescription(false);

            if (!wasExpanded) {
                helpContent.hidden = false;
                button.setAttribute('aria-expanded', 'true');
                openParameterHelpButton = button;
            }
        }

        function renderParameterFields(parameters) {
            clearParameterFields();

            const emptyState = document.getElementById('parameterEmptyState');

            if (!parameters || !parameters.length) {
                emptyState.querySelector('span').textContent = 'O script selecionado não possui parâmetros declarados. Você ainda pode informar parâmetros adicionais abaixo.';
                return;
            }

            const grid = document.getElementById('parameterGrid');
            emptyState.hidden = true;

            parameters.forEach((param, index) => {
                const field = document.createElement('div');
                field.className = 'parameter-field';

                const labelRow = document.createElement('div');
                labelRow.className = 'parameter-label-row';

                const label = document.createElement('label');
                label.setAttribute('for', `param-${param.name}`);
                label.appendChild(document.createTextNode(param.name));

                if (param.mandatory) {
                    const badge = document.createElement('span');
                    badge.className = 'mandatory-badge';
                    badge.textContent = 'Obrigatório';
                    label.appendChild(badge);
                }

                labelRow.appendChild(label);

                if (param.description) {
                    const helpId = `parameter-description-${index}`;
                    const helpWrapper = document.createElement('span');
                    helpWrapper.className = 'parameter-help-wrapper';
                    const helpButton = document.createElement('button');
                    helpButton.type = 'button';
                    helpButton.className = 'parameter-field-help-btn';
                    helpButton.setAttribute('aria-label', `Exibir descrição do parâmetro ${param.name}`);
                    helpButton.setAttribute('aria-expanded', 'false');
                    helpButton.setAttribute('aria-controls', helpId);
                    const helpIcon = document.createElement('i');
                    helpIcon.className = 'fas fa-question';
                    helpIcon.setAttribute('aria-hidden', 'true');
                    helpButton.appendChild(helpIcon);
                    helpButton.addEventListener('click', function () {
                        toggleParameterDescription(helpButton);
                    });
                    helpWrapper.appendChild(helpButton);

                    const fieldHelp = document.createElement('div');
                    fieldHelp.id = helpId;
                    fieldHelp.className = 'parameter-field-help';
                    fieldHelp.hidden = true;
                    fieldHelp.textContent = param.description;
                    helpWrapper.appendChild(fieldHelp);
                    labelRow.appendChild(helpWrapper);
                }

                const input = Array.isArray(param.validateSet) && param.validateSet.length
                    ? document.createElement('select')
                    : document.createElement('input');

                input.id = `param-${param.name}`;
                input.name = `paramValues[${param.name}]`;
                input.required = Boolean(param.mandatory);

                if (input.tagName === 'SELECT') {
                    const emptyOption = document.createElement('option');
                    emptyOption.value = '';
                    emptyOption.textContent = param.description || 'Selecione...';
                    input.appendChild(emptyOption);

                    param.validateSet.forEach((optionValue) => {
                        const option = document.createElement('option');
                        option.value = optionValue;
                        option.textContent = optionValue;
                        input.appendChild(option);
                    });
                } else {
                    input.type = 'text';
                    input.placeholder = param.description || (param.defaultValue
                        ? `Padrao: ${param.defaultValue}`
                        : `Valor de ${param.name}`);

                    if (isPasswordParameter(param)) {
                        input.addEventListener('pointerdown', function (event) {
                            if (event.button === 0) {
                                prepareRestoredPasswordForEditing(input);
                            }
                        });
                        input.addEventListener('beforeinput', function () {
                            prepareRestoredPasswordForEditing(input);
                        });
                    }
                }

                input.addEventListener(input.tagName === 'SELECT' ? 'change' : 'input', function () {
                    scheduleCurrentScriptParametersSave();
                });

                field.appendChild(labelRow);
                field.appendChild(input);

                if (param.type || param.defaultValue) {
                    const meta = document.createElement('div');
                    meta.className = 'parameter-meta';
                    meta.textContent = [
                        param.type ? `Tipo: ${param.type}` : null,
                        param.defaultValue ? `Padrao: ${param.defaultValue}` : null
                    ].filter(Boolean).join(' | ');
                    field.appendChild(meta);
                }

                grid.appendChild(field);
            });
        }

        function getMissingRequiredParameters() {
            const rawParamValues = parseRawNamedParameterValues(
                document.getElementById('params').value,
                selectedParameterDefinitions
            );

            return selectedParameterDefinitions
                .filter((param) => param.mandatory)
                .filter((param) => {
                    const input = document.getElementById(`param-${param.name}`);
                    const structuredValue = input ? input.value.trim() : '';
                    return !structuredValue && !rawParamValues[param.name];
                })
                .map((param) => param.name);
        }

        function parseRawNamedParameterValues(rawParams, parameters) {
            const values = {};
            if (!rawParams || !rawParams.trim()) {
                return values;
            }

            const tokens = rawParams.trim().match(/"[^"]*"|'[^']*'|\S+/g) || [];
            const knownNames = new Map(parameters.map((param) => [param.name.toLowerCase(), param.name]));

            for (let i = 0; i < tokens.length; i++) {
                const token = tokens[i];
                if (!token.startsWith('-')) {
                    continue;
                }

                const canonicalName = knownNames.get(token.slice(1).toLowerCase());
                if (!canonicalName) {
                    continue;
                }

                const nextToken = tokens[i + 1];
                if (!nextToken || nextToken.startsWith('-')) {
                    values[canonicalName] = 'true';
                    continue;
                }

                values[canonicalName] = nextToken.replace(/^['"]|['"]$/g, '');
                i++;
            }

            return values;
        }

        function showExecutionError(message) {
            const status = document.getElementById('executionStatus');
            status.className = 'execution-status error';
            status.innerHTML = `<i class="fas fa-exclamation-circle"></i> ${message}`;
            status.style.display = 'block';
        }

        function clearExecutionStatus() {
            const status = document.getElementById('executionStatus');
            status.style.display = 'none';
            status.className = 'execution-status';
            status.innerHTML = '';
        }
    </script>
</body>

</html>
