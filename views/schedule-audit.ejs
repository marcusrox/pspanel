<!DOCTYPE html>
<html lang="pt-BR" style="font-size: <%= typeof ui !== 'undefined' ? ui.fontScale : '100' %>%;">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Auditoria de agendamentos - PS Panel</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/styles.css">
    <style>
        .container-box { background-color: var(--bg-light); border-radius: 0.5rem; padding: 1.5rem; }
        .audit-filter { display: flex; flex-wrap: wrap; align-items: flex-end; gap: 0.75rem; margin-bottom: 1rem; }
        .audit-filter .form-group { min-width: min(100%, 280px); margin: 0; }
        .audit-filter label { display: block; margin-bottom: 0.35rem; color: var(--text-secondary); font-size: 0.85rem; }
        .audit-filter input { width: 100%; }
        .audit-filter-actions { display: flex; flex-wrap: wrap; gap: 0.5rem; }
        .data-table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
        .data-table th, .data-table td { padding: 0.65rem 0.75rem; text-align: left; border-bottom: 1px solid var(--border-color); vertical-align: top; }
        .data-table th { background: var(--bg-darker); color: var(--text-secondary); }
        .data-table pre { margin: 0; white-space: pre-wrap; word-break: break-word; font-size: 0.8rem; max-width: 480px; }
        .script-name-cell { max-width: 220px; word-break: break-word; }
    </style>
</head>
<body>
    <%- include('partials/sidebar', { activeMenu: 'schedules', user: user }) %>

    <main class="main-content">
        <header class="top-header">
            <div class="header-title">
                <h1>Auditoria de agendamentos</h1>
                <p><a href="/schedules" class="header-back-link"><i class="fas fa-arrow-left" aria-hidden="true"></i> Voltar aos agendamentos</a></p>
            </div>
        </header>

        <% if (messages.error && messages.error.length) { %>
            <div class="alert alert-danger"><%= messages.error[0] %></div>
        <% } %>

        <% const currentFilters = typeof filters !== 'undefined' ? filters : { script_name: '' }; %>

        <div class="container-box">
            <form method="GET" action="/schedules/audit" class="audit-filter">
                <div class="form-group">
                    <label for="script_name">Script</label>
                    <input
                        type="text"
                        id="script_name"
                        name="script_name"
                        value="<%= currentFilters.script_name || '' %>"
                        placeholder="Nome do script .ps1"
                        maxlength="255">
                </div>
                <div class="audit-filter-actions">
                    <button type="submit" class="primary-btn"><i class="fas fa-filter"></i> Filtrar</button>
                    <% if (currentFilters.script_name) { %>
                        <a href="/schedules/audit" class="secondary-btn"><i class="fas fa-times"></i> Limpar</a>
                    <% } %>
                </div>
            </form>

            <% if (!entries.length) { %>
                <p style="color: var(--text-secondary);">Nenhum registro de auditoria.</p>
            <% } else { %>
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Quando</th>
                            <th>Ação</th>
                            <th>Agend. #</th>
                            <th>Script</th>
                            <th>Usuário</th>
                            <th>Detalhes</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% entries.forEach(function (e) { %>
                            <tr>
                                <td><%= new Date(e.created_at).toLocaleString('pt-BR') %></td>
                                <td><%= e.action %></td>
                                <td><%= e.schedule_id != null ? e.schedule_id : '—' %></td>
                                <td class="script-name-cell"><%= e.script_name || '—' %></td>
                                <td><%= e.username || '—' %></td>
                                <td>
                                    <% if (e.details) { %>
                                        <pre><%= e.details %></pre>
                                    <% } else { %>—<% } %>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            <% } %>
        </div>

        <%- include('partials/app-footer') %>
    </main>
</body>
</html>
