<!DOCTYPE html>
<html lang="pt-BR" style="font-size: <%= typeof ui !== 'undefined' ? ui.fontScale : '100' %>%;">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Auditoria de agendamentos - PS Panel</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/styles.css">
    <style>
        .container-box { background-color: var(--bg-light); border-radius: 0.5rem; padding: 1.5rem; }
        .data-table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
        .data-table th, .data-table td { padding: 0.65rem 0.75rem; text-align: left; border-bottom: 1px solid var(--border-color); vertical-align: top; }
        .data-table th { background: var(--bg-darker); color: var(--text-secondary); }
        .data-table pre { margin: 0; white-space: pre-wrap; word-break: break-word; font-size: 0.8rem; max-width: 480px; }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="sidebar-header">
            <a href="/" style="text-decoration: none; color: inherit;">
                <i class="fas fa-terminal"></i>
                <h2>PS Panel</h2>
            </a>
        </div>
        <nav class="sidebar-nav">
            <a href="/"><i class="fas fa-code"></i> Scripts</a>
            <a href="/schedules" class="active"><i class="fas fa-clock"></i> Agendamentos</a>
            <a href="/history"><i class="fas fa-history"></i> Histórico</a>
            <a href="/settings"><i class="fas fa-cog"></i> Configurações</a>
        </nav>
        <div class="sidebar-footer">
            <div class="user-info">
                <span class="user-info1"><i class="fas fa-user"></i> <%= user.displayName || user.username %></span>
            </div>
            <a href="/logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i> Sair</a>
        </div>
    </div>

    <main class="main-content">
        <header class="top-header">
            <div class="header-title">
                <h1>Auditoria de agendamentos</h1>
                <p><a href="/schedules" class="header-back-link"><i class="fas fa-arrow-left" aria-hidden="true"></i> Voltar aos agendamentos</a></p>
            </div>
        </header>

        <% if (messages.error && messages.error.length) { %>
            <div class="alert alert-danger"><%= messages.error[0] %></div>
        <% } %>

        <div class="container-box">
            <% if (!entries.length) { %>
                <p style="color: var(--text-secondary);">Nenhum registro de auditoria.</p>
            <% } else { %>
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Quando</th>
                            <th>Ação</th>
                            <th>Agend. #</th>
                            <th>Usuário</th>
                            <th>Detalhes</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% entries.forEach(function (e) { %>
                            <tr>
                                <td><%= new Date(e.created_at).toLocaleString('pt-BR') %></td>
                                <td><%= e.action %></td>
                                <td><%= e.schedule_id != null ? e.schedule_id : '—' %></td>
                                <td><%= e.username || '—' %></td>
                                <td>
                                    <% if (e.details) { %>
                                        <pre><%= e.details %></pre>
                                    <% } else { %>—<% } %>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            <% } %>
        </div>
    </main>
</body>
</html>
