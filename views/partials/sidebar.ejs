<% const currentMenu = typeof activeMenu !== 'undefined' ? activeMenu : ''; %>

<div class="sidebar">
    <div class="sidebar-header">
        <a href="/" class="sidebar-brand" title="PS Panel" aria-label="PS Panel">
            <i class="fas fa-terminal sidebar-brand-icon" aria-hidden="true"></i>
            <h2 class="sidebar-brand-title" data-text="PS Panel">PS Panel</h2>
        </a>
    </div>
    <nav class="sidebar-nav">
        <a href="/" class="<%= currentMenu === 'scripts' ? 'active' : '' %>" title="Scripts" aria-label="Scripts">
            <i class="fas fa-code"></i>
            <span>Scripts</span>
        </a>
        <a href="/schedules" class="<%= currentMenu === 'schedules' ? 'active' : '' %>" title="Agendamentos" aria-label="Agendamentos">
            <i class="fas fa-clock"></i>
            <span>Agendamentos</span>
        </a>
        <a href="/history" class="<%= currentMenu === 'history' ? 'active' : '' %>" title="Histórico" aria-label="Histórico">
            <i class="fas fa-history"></i>
            <span>Histórico</span>
        </a>
        <a href="/logs" class="<%= currentMenu === 'logs' ? 'active' : '' %>" title="Logs" aria-label="Logs">
            <i class="fas fa-file-lines"></i>
            <span>Logs</span>
        </a>
        <a href="/settings" class="<%= currentMenu === 'settings' ? 'active' : '' %>" title="Configurações" aria-label="Configurações">
            <i class="fas fa-cog"></i>
            <span>Configurações</span>
        </a>
    </nav>
    <div class="sidebar-footer">
        <div class="sidebar-user-card">
            <span class="sidebar-user-avatar" aria-hidden="true">
                <i class="fas fa-user"></i>
            </span>
            <div class="sidebar-user-details">
                <span class="sidebar-user-status"><span class="sidebar-status-dot"></span>Sessão ativa</span>
                <strong class="sidebar-user-name"><%= user.displayName || user.username %></strong>
                <% if (user.email) { %>
                    <span class="sidebar-user-email"><%= user.email %></span>
                <% } %>
            </div>
        </div>

        <div class="sidebar-footer-actions">
            <a href="/runtime-environment" class="sidebar-footer-action sidebar-footer-environment <%= currentMenu === 'runtime-environment' ? 'active' : '' %>" title="Ambiente de execução" aria-label="Ambiente de execução">
                <span class="sidebar-action-icon" aria-hidden="true"><i class="fas fa-server"></i></span>
                <span class="sidebar-action-copy">
                    <strong>Ambiente</strong>
                    <small>Diagnóstico técnico</small>
                </span>
            </a>
            <a href="/logout" class="sidebar-footer-action sidebar-footer-logout" title="Sair" aria-label="Sair">
                <span class="sidebar-action-icon" aria-hidden="true"><i class="fas fa-arrow-right-from-bracket"></i></span>
                <span class="sidebar-action-copy">
                    <strong>Sair</strong>
                    <small>Encerrar sessão</small>
                </span>
            </a>
        </div>
    </div>
</div>
