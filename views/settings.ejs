<!DOCTYPE html>
<html lang="pt-BR" style="font-size: <%= typeof ui !== 'undefined' ? ui.fontScale : '100' %>%;">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Configurações - PS Panel</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/styles.css">
    <style>
        .settings-container {
            padding: 1.5rem;
        }

        .settings-section {
            background-color: var(--bg-light);
            border-radius: 0.5rem;
            padding: 1.5rem;
            margin-bottom: 1.5rem;
        }

        .settings-section h2 {
            color: var(--text-primary);
            font-size: 1.25rem;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

        .form-group label {
            display: block;
            margin-bottom: 0.5rem;
            color: var(--text-secondary);
        }

        .form-group input[type="text"],
        .form-group input[type="number"],
        .form-group input[type="email"],
        .form-group input[type="password"],
        .form-group select {
            width: 100%;
            padding: 0.75rem;
            border: 1px solid var(--border-color);
            border-radius: 0.375rem;
            background-color: var(--bg-darker);
            color: var(--text-primary);
        }

        .form-group input[type="text"]:focus,
        .form-group input[type="number"]:focus,
        .form-group input[type="email"]:focus,
        .form-group input[type="password"]:focus,
        .form-group select:focus {
            border-color: var(--primary-color);
            outline: none;
        }

        .settings-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 1rem;
        }

        .checkbox-field {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            color: var(--text-secondary);
            cursor: pointer;
        }

        .field-hint {
            color: var(--text-secondary);
            font-size: 0.875rem;
            margin-top: 0.35rem;
        }

        .summary-status {
            border-top: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            margin-top: 1rem;
            padding-top: 1rem;
        }

        .summary-status-label {
            color: var(--text-secondary);
            display: block;
            font-size: 0.875rem;
            margin-bottom: 0.25rem;
        }

        .summary-status-value {
            color: var(--text-primary);
            font-weight: 500;
        }

        @media (max-width: 640px) {
            .summary-status {
                align-items: stretch;
                flex-direction: column;
            }
        }

        .form-actions {
            display: flex;
            justify-content: flex-end;
            gap: 1rem;
            margin-top: 2rem;
        }

        .primary-btn,
        .secondary-btn {
            padding: 0.75rem 1.5rem;
            border-radius: 0.375rem;
            font-weight: 500;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            cursor: pointer;
            transition: all 0.2s;
        }

        .primary-btn {
            background-color: var(--primary-color);
            color: white;
            border: none;
        }

        .primary-btn:hover {
            background-color: var(--primary-hover);
        }

        .secondary-btn {
            background-color: transparent;
            color: var(--text-primary);
            border: 1px solid var(--border-color);
        }

        .secondary-btn:hover {
            background-color: var(--bg-darker);
        }
    </style>
</head>
<body>
    <%- include('partials/sidebar', { activeMenu: 'settings', user: user }) %>

    <main class="main-content">
        <header class="top-header">
            <div class="header-title">
                <h1>Configurações</h1>
                <p>Gerencie as configurações do sistema</p>
            </div>
            <div class="header-actions">
                <img src="/logo.png" alt="Logo" class="header-logo">
            </div>
        </header>

        <div class="settings-container">
            <% if (success && success.length) { %>
                <div class="alert alert-success">
                    <%= success[0] %>
                </div>
            <% } %>

            <% if (error && error.length) { %>
                <div class="alert alert-danger">
                    <%= error[0] %>
                </div>
            <% } %>

            <form action="/settings/update" method="POST">
                <div class="settings-section">
                    <h2>
                        <i class="fas fa-clock"></i>
                        Execução
                    </h2>
                    <div class="form-group">
                        <label for="scripts.max_execution_time">Tempo Máximo de Execução (segundos)</label>
                        <input type="number" 
                               id="scripts.max_execution_time" 
                               name="scripts.max_execution_time"
                               value="<%= settings.scripts?.max_execution_time || '3600' %>"
                               min="1">
                    </div>
                </div>

                <div class="settings-section">
                    <h2>
                        <i class="fas fa-font"></i>
                        Aparência
                    </h2>
                    <div class="form-group">
                        <label for="ui.font_scale">Tamanho da fonte</label>
                        <select id="ui.font_scale" name="ui.font_scale">
                            <option value="85" <%= settings.ui?.font_scale === '85' ? 'selected' : '' %>>Super Compacto</option>
                            <option value="90" <%= settings.ui?.font_scale === '90' ? 'selected' : '' %>>Compacto</option>
                            <option value="100" <%= !settings.ui?.font_scale || settings.ui?.font_scale === '100' ? 'selected' : '' %>>Normal</option>
                            <option value="110" <%= settings.ui?.font_scale === '110' ? 'selected' : '' %>>Grande</option>
                        </select>
                    </div>
                </div>

                <div class="settings-section">
                    <h2>
                        <i class="fas fa-envelope"></i>
                        Email - Resumo diário
                    </h2>

                    <div class="form-group">
                        <label class="checkbox-field">
                            <input type="checkbox"
                                   name="email.daily_summary_enabled"
                                   value="1"
                                   <%= settings.email?.daily_summary_enabled === '1' ? 'checked' : '' %>>
                            <span>Enviar resumo diário dos agendamentos</span>
                        </label>
                    </div>

                    <div class="settings-grid">
                        <div class="form-group">
                            <label for="email.smtp_host">Host SMTP</label>
                            <input type="text"
                                   id="email.smtp_host"
                                   name="email.smtp_host"
                                   value="<%= settings.email?.smtp_host || '' %>">
                        </div>

                        <div class="form-group">
                            <label for="email.smtp_port">Porta SMTP</label>
                            <input type="number"
                                   id="email.smtp_port"
                                   name="email.smtp_port"
                                   value="<%= settings.email?.smtp_port || '587' %>"
                                   min="1"
                                   max="65535">
                        </div>
                    </div>

                    <div class="settings-grid">
                        <div class="form-group">
                            <label for="email.smtp_user">Usuário SMTP</label>
                            <input type="text"
                                   id="email.smtp_user"
                                   name="email.smtp_user"
                                   value="<%= settings.email?.smtp_user || '' %>"
                                   autocomplete="username">
                        </div>

                        <div class="form-group">
                            <label for="email.smtp_pass">Senha SMTP</label>
                            <input type="password"
                                   id="email.smtp_pass"
                                   name="email.smtp_pass"
                                   value=""
                                   placeholder="<%= settings.email?.smtp_pass ? 'Senha configurada' : '' %>"
                                   autocomplete="new-password">
                            <p class="field-hint">Deixe em branco para manter a senha atual.</p>
                        </div>
                    </div>

                    <div class="settings-grid">
                        <div class="form-group">
                            <label for="email.from_address">Email remetente</label>
                            <input type="email"
                                   id="email.from_address"
                                   name="email.from_address"
                                   value="<%= settings.email?.from_address || '' %>">
                        </div>

                        <div class="form-group">
                            <label for="email.daily_summary_recipient">Destinatário do resumo</label>
                            <input type="email"
                                   id="email.daily_summary_recipient"
                                   name="email.daily_summary_recipient"
                                   value="<%= settings.email?.daily_summary_recipient || '' %>">
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="checkbox-field">
                            <input type="checkbox"
                                   name="email.smtp_secure"
                                   value="1"
                                   <%= settings.email?.smtp_secure === '1' ? 'checked' : '' %>>
                            <span>Usar SSL/TLS direto</span>
                        </label>
                        <p class="field-hint">Marque apenas para SMTP SSL/TLS direto, normalmente porta 465. Para porta 587 com STARTTLS, deixe desmarcado.</p>
                    </div>

                    <div class="summary-status">
                        <div>
                            <span class="summary-status-label">Último envio</span>
                            <span class="summary-status-value"><%= dailySummaryStatus?.displayText || 'Nunca enviado' %></span>
                        </div>
                        <button type="submit"
                                form="send-daily-summary-form"
                                class="secondary-btn"
                                onclick="return confirm('Enviar o resumo diário agora?');">
                            <i class="fas fa-paper-plane"></i>
                            Enviar resumo agora
                        </button>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="reset" class="secondary-btn">
                        <i class="fas fa-undo"></i>
                        Restaurar
                    </button>
                    <button type="submit" class="primary-btn">
                        <i class="fas fa-save"></i>
                        Salvar Alterações
                    </button>
                </div>
            </form>
            <form id="send-daily-summary-form" action="/settings/daily-summary/send-now" method="POST"></form>
        </div>
    </main>
</body>
</html> 
