<!DOCTYPE html>
<html lang="pt-BR" style="font-size: <%= typeof ui !== 'undefined' ? ui.fontScale : '100' %>%;">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Configurações - PS Panel</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/styles.css">
    <style>
        .settings-container {
            padding: 1.5rem;
        }

        .settings-section {
            background-color: var(--bg-light);
            border-radius: 0.5rem;
            margin-bottom: 1.5rem;
            overflow: hidden;
        }

        .settings-section h2 {
            margin: 0;
        }

        .settings-accordion-toggle {
            width: 100%;
            border: 0;
            background: transparent;
            color: var(--text-primary);
            font-size: 1.25rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            justify-content: space-between;
            padding: 1.5rem;
            text-align: left;
        }

        .settings-accordion-toggle:hover,
        .settings-accordion-toggle:focus-visible {
            background-color: rgba(255, 255, 255, 0.03);
            outline: none;
        }

        .settings-accordion-title {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            min-width: 0;
        }

        .settings-accordion-chevron {
            color: var(--text-secondary);
            flex: 0 0 auto;
            transition: transform 0.2s ease;
        }

        .settings-accordion-toggle[aria-expanded="true"] .settings-accordion-chevron {
            transform: rotate(90deg);
        }

        .settings-accordion-content {
            padding: 0 1.5rem 1.5rem;
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

        .form-group label {
            display: block;
            margin-bottom: 0.5rem;
            color: var(--text-secondary);
        }

        .form-group input[type="text"],
        .form-group input[type="number"],
        .form-group input[type="email"],
        .form-group input[type="password"],
        .form-group select {
            width: 100%;
            padding: 0.75rem;
            border: 1px solid var(--border-color);
            border-radius: 0.375rem;
            background-color: var(--bg-darker);
            color: var(--text-primary);
        }

        .form-group input[type="text"]:focus,
        .form-group input[type="number"]:focus,
        .form-group input[type="email"]:focus,
        .form-group input[type="password"]:focus,
        .form-group select:focus {
            border-color: var(--primary-color);
            outline: none;
        }

        .settings-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 1rem;
        }

        .form-group label.checkbox-field {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            color: var(--text-secondary);
            cursor: pointer;
            margin-bottom: 0.5rem;
        }

        .form-group label.checkbox-field input[type="checkbox"] {
            flex: 0 0 auto;
            margin: 0;
            padding: 0;
            width: auto;
        }

        .field-hint {
            color: var(--text-secondary);
            font-size: 0.875rem;
            margin-top: 0.35rem;
            margin-bottom: 0;
        }

        .summary-status {
            border-top: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            margin-top: 1rem;
            padding-top: 1rem;
        }

        .summary-status-label {
            color: var(--text-secondary);
            display: block;
            font-size: 0.875rem;
            margin-bottom: 0.25rem;
        }

        .summary-status-value {
            color: var(--text-primary);
            font-weight: 500;
        }

        @media (max-width: 640px) {
            .summary-status {
                align-items: stretch;
                flex-direction: column;
            }

            .settings-accordion-toggle {
                align-items: flex-start;
                padding: 1rem;
            }

            .settings-accordion-content {
                padding: 0 1rem 1rem;
            }
        }

        .form-actions {
            display: flex;
            justify-content: flex-end;
            gap: 1rem;
            margin-top: 2rem;
        }

        .primary-btn,
        .secondary-btn {
            padding: 0.75rem 1.5rem;
            border-radius: 0.375rem;
            font-weight: 500;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            cursor: pointer;
            transition: all 0.2s;
        }

        .primary-btn {
            background-color: var(--primary-color);
            color: white;
            border: none;
        }

        .primary-btn:hover {
            background-color: var(--primary-hover);
        }

        .secondary-btn {
            background-color: transparent;
            color: var(--text-primary);
            border: 1px solid var(--border-color);
        }

        .secondary-btn:hover {
            background-color: var(--bg-darker);
        }
    </style>
</head>
<body>
    <%- include('partials/sidebar', { activeMenu: 'settings', user: user }) %>

    <main class="main-content">
        <header class="top-header">
            <div class="header-title">
                <h1>Configurações</h1>
                <p>Gerencie as configurações do sistema</p>
            </div>
            <div class="header-actions">
                <img src="/logo.png" alt="Logo" class="header-logo">
            </div>
        </header>

        <div class="settings-container">
            <% const pageMessages = typeof messages !== 'undefined' ? messages : { success: [], error: [] }; %>
            <% if (pageMessages.success && pageMessages.success.length) { %>
                <div class="alert alert-success">
                    <%= pageMessages.success[0] %>
                </div>
            <% } %>

            <% if (pageMessages.error && pageMessages.error.length) { %>
                <div class="alert alert-danger">
                    <%= pageMessages.error[0] %>
                </div>
            <% } %>

            <form action="/settings/update" method="POST">
                <div class="settings-section" data-section-key="execution">
                    <h2>
                        <button
                            type="button"
                            id="settings-section-execution-title"
                            class="settings-accordion-toggle"
                            aria-expanded="true"
                            aria-controls="settings-section-execution-content">
                            <span class="settings-accordion-title">
                                <i class="fas fa-clock"></i>
                                Execução
                            </span>
                            <i class="fas fa-chevron-right settings-accordion-chevron" aria-hidden="true"></i>
                        </button>
                    </h2>
                    <div
                        id="settings-section-execution-content"
                        class="settings-accordion-content"
                        aria-labelledby="settings-section-execution-title">
                        <div class="form-group">
                            <label for="scripts.max_execution_time">Tempo Máximo de Execução (segundos)</label>
                            <input type="number"
                                   id="scripts.max_execution_time"
                                   name="scripts.max_execution_time"
                                   value="<%= settings.scripts?.max_execution_time || '3600' %>"
                                   min="1">
                        </div>
                    </div>
                </div>

                <div class="settings-section" data-section-key="appearance">
                    <h2>
                        <button
                            type="button"
                            id="settings-section-appearance-title"
                            class="settings-accordion-toggle"
                            aria-expanded="true"
                            aria-controls="settings-section-appearance-content">
                            <span class="settings-accordion-title">
                                <i class="fas fa-font"></i>
                                Aparência
                            </span>
                            <i class="fas fa-chevron-right settings-accordion-chevron" aria-hidden="true"></i>
                        </button>
                    </h2>
                    <div
                        id="settings-section-appearance-content"
                        class="settings-accordion-content"
                        aria-labelledby="settings-section-appearance-title">
                        <div class="form-group">
                            <label for="ui.font_scale">Tamanho da fonte</label>
                            <select id="ui.font_scale" name="ui.font_scale">
                                <option value="85" <%= settings.ui?.font_scale === '85' ? 'selected' : '' %>>Super Compacto</option>
                                <option value="90" <%= settings.ui?.font_scale === '90' ? 'selected' : '' %>>Compacto</option>
                                <option value="100" <%= !settings.ui?.font_scale || settings.ui?.font_scale === '100' ? 'selected' : '' %>>Normal</option>
                                <option value="110" <%= settings.ui?.font_scale === '110' ? 'selected' : '' %>>Grande</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="settings-section" data-section-key="authenticationAccess">
                    <h2>
                        <button
                            type="button"
                            id="settings-section-authentication-title"
                            class="settings-accordion-toggle"
                            aria-expanded="false"
                            aria-controls="settings-section-authentication-content">
                            <span class="settings-accordion-title">
                                <i class="fas fa-user-shield"></i>
                                Autenticação e acesso
                            </span>
                            <i class="fas fa-chevron-right settings-accordion-chevron" aria-hidden="true"></i>
                        </button>
                    </h2>
                    <div
                        id="settings-section-authentication-content"
                        class="settings-accordion-content"
                        aria-labelledby="settings-section-authentication-title"
                        hidden>
                        <div class="form-group">
                            <label for="auth.allowed_ad_group_dn">Grupo do Active Directory permitido</label>
                            <input type="text"
                                   id="auth.allowed_ad_group_dn"
                                   name="auth.allowed_ad_group_dn"
                                   value="<%= settings.auth?.allowed_ad_group_dn || '' %>"
                                   maxlength="1024"
                                   autocomplete="off"
                                   placeholder="CN=PSPanel-Usuarios,OU=Groups,DC=exemplo,DC=local">
                            <p class="field-hint">Informe o DN completo do grupo. A verificação considera associação direta pelo atributo <code>memberOf</code>.</p>
                            <p class="field-hint"><strong>Atenção:</strong> enquanto este campo estiver vazio, qualquer usuário autenticado no AD poderá acessar o PS Panel.</p>
                        </div>
                    </div>
                </div>

                <div class="settings-section" data-section-key="smtp">
                    <h2>
                        <button
                            type="button"
                            id="settings-section-smtp-title"
                            class="settings-accordion-toggle"
                            aria-expanded="false"
                            aria-controls="settings-section-smtp-content">
                            <span class="settings-accordion-title">
                                <i class="fas fa-server"></i>
                                Email - Servidor SMTP
                            </span>
                            <i class="fas fa-chevron-right settings-accordion-chevron" aria-hidden="true"></i>
                        </button>
                    </h2>

                    <div
                        id="settings-section-smtp-content"
                        class="settings-accordion-content"
                        aria-labelledby="settings-section-smtp-title"
                        hidden>
                        <p class="field-hint">Configuração compartilhada pelo resumo diário e pelos scripts PowerShell que enviam email.</p>

                        <div class="settings-grid">
                            <div class="form-group">
                                <label for="smtp.host">Host SMTP</label>
                                <input type="text"
                                       id="smtp.host"
                                       name="smtp.host"
                                       value="<%= smtpConfig?.host || '' %>"
                                       autocomplete="off">
                            </div>

                            <div class="form-group">
                                <label for="smtp.port">Porta e segurança</label>
                                <select id="smtp.port" name="smtp.port">
                                    <option value="587" <%= smtpConfig?.port === 587 ? 'selected' : '' %>>587 - STARTTLS obrigatório</option>
                                    <option value="465" <%= smtpConfig?.port === 465 ? 'selected' : '' %>>465 - TLS implícito</option>
                                </select>
                            </div>
                        </div>

                        <div class="settings-grid">
                            <div class="form-group">
                                <label for="smtp.username">Usuário SMTP</label>
                                <input type="text"
                                       id="smtp.username"
                                       name="smtp.username"
                                       value="<%= smtpConfig?.username || '' %>"
                                       autocomplete="username">
                            </div>

                            <div class="form-group">
                                <label for="smtp.password">Senha SMTP</label>
                                <input type="password"
                                       id="smtp.password"
                                       name="smtp.password"
                                       value=""
                                       placeholder="<%= smtpConfig?.passwordConfigured ? 'Senha configurada' : '' %>"
                                       autocomplete="new-password">
                                <p class="field-hint">Deixe em branco para manter a senha atual.</p>
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="smtp.fromAddress">Email remetente</label>
                            <input type="text"
                                   id="smtp.fromAddress"
                                   name="smtp.fromAddress"
                                   value="<%= smtpConfig?.fromAddress || '' %>"
                                   placeholder='"PS Panel" <naoresponda@exemplo.com>'>
                            <p class="field-hint">Aceita apenas o email ou o formato Nome &lt;email@dominio&gt;.</p>
                        </div>

                        <p class="field-hint">A senha é armazenada fora do Git. O acesso ao arquivo deve ser controlado pelas permissões do sistema operacional. Certificados inválidos não são aceitos.</p>
                    </div>
                </div>

                <div class="settings-section" data-section-key="emailDailySummary">
                    <h2>
                        <button
                            type="button"
                            id="settings-section-email-title"
                            class="settings-accordion-toggle"
                            aria-expanded="false"
                            aria-controls="settings-section-email-content">
                            <span class="settings-accordion-title">
                                <i class="fas fa-envelope"></i>
                                Email - Resumo diário
                            </span>
                            <i class="fas fa-chevron-right settings-accordion-chevron" aria-hidden="true"></i>
                        </button>
                    </h2>

                    <div
                        id="settings-section-email-content"
                        class="settings-accordion-content"
                        aria-labelledby="settings-section-email-title"
                        hidden>

                    <div class="form-group">
                        <label class="checkbox-field">
                            <input type="checkbox"
                                   name="email.daily_summary_enabled"
                                   value="1"
                                   <%= settings.email?.daily_summary_enabled === '1' ? 'checked' : '' %>>
                            <span>Enviar resumo diário dos agendamentos</span>
                        </label>
                    </div>

                    <div class="form-group">
                        <label for="email.daily_summary_recipient">Destinatário do resumo</label>
                        <input type="email"
                               id="email.daily_summary_recipient"
                               name="email.daily_summary_recipient"
                               value="<%= settings.email?.daily_summary_recipient || '' %>">
                    </div>

                    <div class="summary-status">
                        <div>
                            <span class="summary-status-label">Último envio</span>
                            <span class="summary-status-value"><%= dailySummaryStatus?.displayText || 'Nunca enviado' %></span>
                        </div>
                        <button type="submit"
                                form="send-daily-summary-form"
                                class="secondary-btn"
                                onclick="return confirm('Enviar o resumo diário agora?');">
                            <i class="fas fa-paper-plane"></i>
                            Enviar resumo agora
                        </button>
                    </div>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="reset" class="secondary-btn">
                        <i class="fas fa-undo"></i>
                        Restaurar
                    </button>
                    <button type="submit" class="primary-btn">
                        <i class="fas fa-save"></i>
                        Salvar Alterações
                    </button>
                </div>
            </form>
            <form id="send-daily-summary-form" action="/settings/daily-summary/send-now" method="POST"></form>
        </div>

        <%- include('partials/app-footer') %>
    </main>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const storageKey = 'pspanel.settings.accordion';
            const defaultState = {
                execution: true,
                appearance: true,
                authenticationAccess: false,
                smtp: false,
                emailDailySummary: false
            };

            function readStoredState() {
                try {
                    const rawState = localStorage.getItem(storageKey);
                    if (!rawState) {
                        return {};
                    }

                    const parsedState = JSON.parse(rawState);
                    return parsedState && typeof parsedState === 'object' ? parsedState : {};
                } catch (error) {
                    return {};
                }
            }

            function writeStoredState(state) {
                try {
                    localStorage.setItem(storageKey, JSON.stringify(state));
                } catch (error) {
                    // A preferencia visual e opcional; falhas de storage nao devem bloquear a tela.
                }
            }

            function setSectionState(section, isOpen) {
                const toggle = section.querySelector('.settings-accordion-toggle');
                const content = section.querySelector('.settings-accordion-content');

                toggle.setAttribute('aria-expanded', String(isOpen));
                content.hidden = !isOpen;
                section.classList.toggle('is-collapsed', !isOpen);
            }

            const storedState = readStoredState();
            const accordionState = Object.assign({}, defaultState, storedState);

            document.querySelectorAll('.settings-section[data-section-key]').forEach(function (section) {
                const sectionKey = section.dataset.sectionKey;
                const toggle = section.querySelector('.settings-accordion-toggle');
                const isOpen = Boolean(accordionState[sectionKey]);

                setSectionState(section, isOpen);

                toggle.addEventListener('click', function () {
                    const nextState = toggle.getAttribute('aria-expanded') !== 'true';
                    accordionState[sectionKey] = nextState;
                    setSectionState(section, nextState);
                    writeStoredState(accordionState);
                });
            });
        });
    </script>
</body>
</html> 
