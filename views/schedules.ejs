<!DOCTYPE html>
<html lang="pt-BR" style="font-size: <%= typeof ui !== 'undefined' ? ui.fontScale : '100' %>%;">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Agendamentos - PS Panel</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/styles.css">
    <style>
        .container-box { background-color: var(--bg-light); border-radius: 0.5rem; padding: 1.5rem; margin-bottom: 1.5rem; }
        .toolbar { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-bottom: 1.25rem; align-items: center; }
        .data-table { width: 100%; border-collapse: collapse; }
        .data-table th, .data-table td { padding: 0.75rem 1rem; text-align: left; border-bottom: 1px solid var(--border-color); }
        .data-table th { background: var(--bg-darker); color: var(--text-secondary); font-weight: 500; }
        .data-table tr:hover { background: var(--bg-darker); }
        .badge-off { opacity: 0.6; }
        .schedule-actions-cell { width: 8.25rem; text-align: right; white-space: nowrap; }
        .schedule-action-buttons {
            display: inline-flex;
            align-items: center;
            justify-content: flex-end;
            gap: 0.4rem;
        }
        .schedule-action-buttons form { margin: 0; }
        .schedule-action-btn {
            width: 2.25rem;
            height: 2.25rem;
            padding: 0;
            border: 1px solid var(--border-color);
            border-radius: 0.375rem;
            background-color: var(--bg-light);
            color: var(--text-secondary);
            cursor: pointer;
            text-decoration: none;
            flex-shrink: 0;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: background-color 0.15s ease, color 0.15s ease, border-color 0.15s ease;
        }
        .schedule-action-btn:hover,
        .schedule-action-btn:focus {
            background-color: rgba(37, 99, 235, 0.12);
            border-color: var(--primary-color);
            color: var(--primary-color);
            outline: none;
        }
        .schedule-delete-btn:hover,
        .schedule-delete-btn:focus {
            background-color: rgba(220, 38, 38, 0.12);
            border-color: #dc2626;
            color: #f87171;
        }
        .details-modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.5);
            z-index: 1000;
        }
        .modal-content {
            position: relative;
            background-color: var(--bg-light);
            margin: 5% auto;
            padding: 2rem;
            width: 80%;
            max-width: 800px;
            border-radius: 0.5rem;
            max-height: 80vh;
            overflow-y: auto;
        }
        .close-modal {
            position: absolute;
            top: 1rem;
            right: 1rem;
            font-size: 1.5rem;
            cursor: pointer;
            color: var(--text-secondary);
            border: 0;
            background: transparent;
            line-height: 1;
        }
        .close-modal:hover,
        .close-modal:focus {
            color: var(--text-primary);
            outline: none;
        }
        .schedule-detail-list {
            display: grid;
            gap: 0.75rem;
            margin-bottom: 1.25rem;
        }
        .schedule-detail-list p {
            margin: 0;
        }
        .output-container {
            background-color: var(--bg-darker);
            padding: 1rem;
            border-radius: 0.375rem;
            margin-top: 1rem;
            font-family: monospace;
            white-space: pre-wrap;
            max-height: 400px;
            overflow-y: auto;
        }
    </style>
</head>
<body>
    <%- include('partials/sidebar', { activeMenu: 'schedules', user: user }) %>

    <main class="main-content">
        <header class="top-header">
            <div class="header-title">
                <h1>Agendamentos</h1>
                <p>Execuções agendadas de scripts PowerShell</p>
            </div>
            <div class="header-actions">
                <img src="/logo.png" alt="Logo" class="header-logo">
            </div>
        </header>

        <% if (messages.error && messages.error.length) { %>
            <div class="alert alert-danger"><%= messages.error[0] %></div>
        <% } %>
        <% if (messages.success && messages.success.length) { %>
            <div class="alert alert-success"><%= messages.success[0] %></div>
        <% } %>

        <div class="container-box">
            <div class="toolbar">
                <a href="/schedules/new" class="primary-btn"><i class="fas fa-plus"></i> Novo agendamento</a>
                <a href="/schedules/audit" class="secondary-btn"><i class="fas fa-clipboard-list"></i> Auditoria</a>
            </div>

            <% if (!schedules.length) { %>
                <p style="color: var(--text-secondary);">Nenhum agendamento cadastrado.</p>
            <% } else { %>
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Ativo</th>
                            <th>Script</th>
                            <th>Parâmetros</th>
                            <th>Próxima execução</th>
                            <th>Repetir (min)</th>
                            <th>Última execução</th>
                            <th>Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% schedules.forEach(function (s) { %>
                            <tr class="<%= s.enabled ? '' : 'badge-off' %>">
                                <td><%= s.enabled ? 'Sim' : 'Não' %></td>
                                <td><%= s.script_name %></td>
                                <td><%= s.parameters || '—' %></td>
                                <td><%= new Date(s.next_run_at).toLocaleString('pt-BR') %></td>
                                <td><%= s.repeat_interval_minutes != null ? s.repeat_interval_minutes : '— (uma vez)' %></td>
                                <td><%= s.last_run_at ? new Date(s.last_run_at).toLocaleString('pt-BR') : '—' %></td>
                                <td class="schedule-actions-cell">
                                    <div class="schedule-action-buttons">
                                        <button
                                            type="button"
                                            class="schedule-action-btn"
                                            title="Ver detalhes"
                                            aria-label="Ver detalhes da última execução"
                                            data-script="<%= s.script_name %>"
                                            data-parameters="<%= s.parameters || '' %>"
                                            data-last-run="<%= s.last_run_at ? new Date(s.last_run_at).toLocaleString('pt-BR') : '' %>"
                                            data-exit-code="<%= s.last_run_exit_code != null ? s.last_run_exit_code : '' %>"
                                            data-output="<%= s.last_run_output || '' %>"
                                            onclick="showScheduleDetails(this)"
                                        >
                                            <i class="fas fa-eye" aria-hidden="true"></i>
                                        </button>
                                        <a href="/schedules/<%= s.id %>/edit" class="schedule-action-btn" title="Editar" aria-label="Editar agendamento">
                                            <i class="fas fa-edit" aria-hidden="true"></i>
                                        </a>
                                        <form action="/schedules/<%= s.id %>/delete" method="POST" onsubmit="return confirm('Excluir este agendamento?');">
                                            <button type="submit" class="schedule-action-btn schedule-delete-btn" title="Excluir" aria-label="Excluir agendamento">
                                                <i class="fas fa-trash-alt" aria-hidden="true"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            <% } %>
        </div>

        <p style="color: var(--text-secondary); font-size: 0.9rem;">
            O processamento no horário usa o script <code>scripts-ps/Invoke-ScheduleWorker.ps1</code> + <code>scripts-js/schedule-worker.js</code> (Task Scheduler, ex.: a cada 5 minutos).
        </p>

        <%- include('partials/app-footer') %>
    </main>

    <div id="scheduleDetailsModal" class="details-modal" aria-hidden="true">
        <div class="modal-content" role="dialog" aria-modal="true" aria-labelledby="scheduleDetailsTitle">
            <button type="button" class="close-modal" onclick="closeScheduleDetails()" aria-label="Fechar">&times;</button>
            <h2 id="scheduleDetailsTitle">Detalhes da última execução</h2>
            <div class="schedule-detail-list">
                <p><strong>Script:</strong> <span id="detailScript"></span></p>
                <p><strong>Parâmetros:</strong> <span id="detailParameters"></span></p>
                <p><strong>Última execução:</strong> <span id="detailLastRun"></span></p>
                <p><strong>Código de saída:</strong> <span id="detailExitCode"></span></p>
            </div>
            <h3>Saída</h3>
            <div id="detailOutput" class="output-container"></div>
        </div>
    </div>

    <script>
        function setDetailText(id, value, fallback) {
            const element = document.getElementById(id);
            element.textContent = value || fallback;
        }

        function showScheduleDetails(button) {
            const modal = document.getElementById('scheduleDetailsModal');

            setDetailText('detailScript', button.dataset.script, '—');
            setDetailText('detailParameters', button.dataset.parameters, 'Nenhum');
            setDetailText('detailLastRun', button.dataset.lastRun, 'Ainda não executado');
            setDetailText('detailExitCode', button.dataset.exitCode, 'Não registrado');
            setDetailText('detailOutput', button.dataset.output, 'Sem saída registrada');

            modal.style.display = 'block';
            modal.setAttribute('aria-hidden', 'false');
        }

        function closeScheduleDetails() {
            const modal = document.getElementById('scheduleDetailsModal');
            modal.style.display = 'none';
            modal.setAttribute('aria-hidden', 'true');
        }

        window.addEventListener('click', function (event) {
            const modal = document.getElementById('scheduleDetailsModal');
            if (event.target === modal) {
                closeScheduleDetails();
            }
        });
    </script>
</body>
</html>
